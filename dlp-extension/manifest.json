{
  "manifest_version": 3,
  "name": "AI DLP Firewall – חומת אש למניעת דליפת מידע",
  "description": "מונע מעובדים להדביק מידע רגיש של החברה בצ'אטבוטים של AI.",
  "version": "1.0.0",
  "default_locale": "he",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css", "styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "identity", "identity.email", "alarms", "activeTab", "contextMenus"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["dlp-worker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}