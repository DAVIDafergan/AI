# DLP Shield Configuration
DLP_SERVER_URL=http://localhost:3000
DLP_DEFAULT_ORG=default-org
DLP_ADMIN_SECRET=change-me-in-production
NODE_ENV=development

# Desktop Shield
DLP_API_KEY=dev-api-key-12345
DLP_POLLING_INTERVAL=500
DLP_NOTIFICATIONS=true
DLP_VERBOSE=false

# MongoDB (required for multi-tenant features)
MONGODB_URI=mongodb://mongo:CJIYYeWjRwoQChiJPyxBjQGbqbsfgQeu@ballast.proxy.rlwy.net:56402

# Redis (used for rate limiting)
REDIS_URL=redis://redis:6379
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# Super Admin Dashboard
# Generate a strong random value, e.g.: openssl rand -hex 32
SUPER_ADMIN_KEY=change-me-to-a-strong-secret

# Super Admin login credentials (username/password for the login form at /)
SUPER_ADMIN_USERNAME=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password-here

# JWT secret used to sign and verify session tokens (super-admin cookie)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-jwt-secret

# Comma-separated list of allowed CORS origins (includes chrome-extension:// IDs)
# Example: https://app.example.com,chrome-extension://abcdefghijklmnopabcdefghijklmnop
ALLOWED_ORIGINS=https://app.example.com,chrome-extension://your-extension-id

# HMAC secret used to hash API keys before storing them in MongoDB.
# The database stores only HMAC-SHA256 digests; raw keys are never persisted.
# Generate with: openssl rand -hex 32
API_KEY_HMAC_SECRET=61b28045e319e1ec4c8c6389b79cc8af380fb7d8a54dae6200f84ba7d2dd1724

# ── Sprint 3: Enterprise SSO (OIDC) ──────────────────────────────────────────
# Auth.js (next-auth) settings – required for SSO login
# Generate NEXTAUTH_SECRET with: openssl rand -hex 32
NEXTAUTH_URL=https://app.example.com
NEXTAUTH_SECRET=change-me-to-a-strong-nextauth-secret

# Generic OIDC provider (works with Okta, Microsoft Entra ID, Google, etc.)
# Leave blank to disable SSO login and rely solely on API-key auth.
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
# Optional: display name shown on the login button (default: "Enterprise SSO")
OIDC_PROVIDER_NAME=Okta
