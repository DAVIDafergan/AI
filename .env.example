# GhostLayer – Docker Environment Configuration
# Copy this file to .env (in this root directory) and fill in your values:
#   cp .env.example .env

# MongoDB connection string (required)
MONGODB_URI=mongodb://<username>:<password>@<host>:<port>/<database>?authSource=admin

# Super Admin credentials (required – choose strong values)
SUPER_ADMIN_KEY=change-me-to-a-strong-secret
SUPER_ADMIN_USERNAME=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password-here

# DLP server settings
DLP_SERVER_URL=http://localhost:3000
DLP_DEFAULT_ORG=default-org
DLP_ADMIN_SECRET=change-me-in-production

# Desktop Shield / agent settings
DLP_API_KEY=dev-api-key-12345
DLP_POLLING_INTERVAL=500
DLP_NOTIFICATIONS=true
DLP_VERBOSE=false

# Redis – local agent state (fragment cache + UBA behavior profiles)
# Used by the ghostlayer-local-agent to persist fragment windows and user profiles
# across restarts.  The Redis service is included in docker-compose.yml.
REDIS_URL=redis://redis:6379

# Qdrant – local vector database (semantic similarity search)
# Used by the ghostlayer-local-agent to store and query document embeddings.
# The Qdrant service is included in docker-compose.yml.
QDRANT_URL=http://qdrant:6333
