{
  "manifest_version": 3,
  "name": "AI DLP Firewall – חומת אש למניעת דליפת מידע",
  "description": "מונע מעובדים להדביק מידע רגיש של החברה בצ'אטבוטים של AI.",
  "version": "1.0.0",
  "default_locale": "he",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"]
}