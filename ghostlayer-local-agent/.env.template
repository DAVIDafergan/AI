# ─────────────────────────────────────────────────────────────────────────────
# GhostLayer Local Agent – Environment Template
#
# Steps:
#   1. Copy this file:   cp .env.template .env
#   2. Fill in the values below
#   3. Place your corporate documents in the ./corporate_data folder
#   4. Run:              docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Tenant API key – copy from your GhostLayer dashboard
API_KEY=

# GhostLayer SaaS base URL (e.g. https://app.ghostlayer.io or your self-hosted URL)
SERVER_URL=

# ── Optional ──────────────────────────────────────────────────────────────────

# Port exposed on the host for browser extensions to reach the local API
# Default: 4000
LOCAL_PORT=4000

# Set to "true" for detailed pipeline logging
# Default: false
VERBOSE=false
